<?xml version="1.0" encoding="UTF-8"?>
<kcfg xmlns="http://www.kde.org/standards/kcfg/1.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.kde.org/standards/kcfg/1.0 http://www.kde.org/standards/kcfg/1.0/kcfg.xsd">
    <kcfgfile name=""/>

    <group name="General">
        <entry name="videoPath" type="String">
            <default></default>
        </entry>
        <entry name="videoSpeed" type="String">
            <default>1</default>
        </entry>
        <entry name="videoVolume" type="String">
            <default>1</default>
        </entry>
        <entry name="videoMuted" type="Bool">
            <default>false</default>
        </entry>
        <entry name="enableTimeSeek" type="Bool">
            <default>false</default>
        </entry>

        <entry name="videoFillMode" type="Real">
            <default>0</default>
        </entry>
        <entry name="noBackground" type="Bool">
            <default>false</default>
        </entry>
        <entry name="videoOpacity" type="String">
            <default>1</default>
        </entry>

        <entry name="videoMirrored" type="Real">
            <default>false</default>
        </entry>
    </group>
</kcfg>
